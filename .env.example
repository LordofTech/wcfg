# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# SMTP for lead notifications (no domain verification required)
# Production uses the domain mail host (cPanel): mail.wcfgbizbrokers.com
# For Google Workspace, use smtp.gmail.com + an App Password instead.
SMTP_HOST=mail.wcfgbizbrokers.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your_mailbox_password
# Optional. Defaults to: WCFG Consultations <SMTP_USER>
SMTP_FROM=WCFG Consultations <you@yourdomain.com>
# Inbox that receives new consultation leads
LEADS_NOTIFY_EMAIL=jay@wcfgluxauto.com
